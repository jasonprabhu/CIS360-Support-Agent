# Server Configuration
PORT=3978

# Microsoft Bot Framework Configuration
# For local testing with Bot Framework Emulator, leave these blank
MicrosoftAppId=
MicrosoftAppPassword=
MicrosoftAppType=MultiTenant
MicrosoftAppTenantId=

# ServiceNow Integration Configuration
SERVICENOW_MOCK=true
SERVICENOW_URL=https://devXXXXX.service-now.com
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your_password

# Support Escalation Configuration
# Conversation ID of the Teams Channel where human agents receive escalation requests
SUPPORT_CHANNEL_ID=support-agent-channel-id

# Microsoft 365 Tenant Integration Configuration
M365_MOCK=true
M365_TENANT_ID=your_tenant_guid_or_domain
M365_CLIENT_ID=your_registered_entra_app_client_id
M365_CLIENT_SECRET=your_registered_entra_app_client_secret

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1
