{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.15/MicrosoftTeams.schema.json",
  "manifestVersion": "1.15",
  "version": "1.1.0",
  "id": "f598bc5d-5bdc-483a-a254-3ba923e38d63",
  "packageName": "com.cis360.support",
  "developer": {
    "name": "CIS360 Support Team",
    "websiteUrl": "https://github.com/jasonprabhu/CIS360-Support-Agent",
